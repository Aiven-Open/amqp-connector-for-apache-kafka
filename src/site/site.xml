<site xmlns="http://maven.apache.org/SITE/2.1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SITE/2.1.0 https://maven.apache.org/xsd/site-2.1.0.xsd">

    <bannerLeft name="Aiven connectors for AMQP on Apache Kafka" href="https://aiven.io" >
        <image width="32px" height="32px" src="./logo.png"/>
    </bannerLeft>

    <poweredBy>
        <logo name="Aiven" href="https://aiven.io/">
            <image src="./logo.png"/>
        </logo>
    </poweredBy>

    <body>
        <head>
            <![CDATA[
                <link rel="icon" type="image/svg+xml" href="./logo.svg">
                <link rel="icon" type="image/png" href="./logo.png">
                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        document.querySelectorAll('a.builtBy, #bannerLeft a').forEach(function (link) {
                            link.target = '_blank';
                            link.rel = 'noopener noreferrer';
                        });
                    });
                </script>
            ]]>
        </head>

        <breadcrumbs>
            <item name="Home" href="./index.html" />
        </breadcrumbs>

        <menu name="Overview" inherit="bottom" inheritAsRef="true">
            <item name="Introduction" href="./index.html"/>
            <item name="Source Connector" href="./source/index.html">
                <item name="Architecture" href="./source/architecture.html"/>
                <item name="Configuration" href="./source/configuration.html"/>
            </item>
            <item name="Change log" href="./CHANGE_LOG.html" />
        </menu>

        <menu name="Getting Involved" inherit="bottom" inheritAsRef="true">
            <item name="Code of Conduct" href="./CODE_OF_CONDUCT.html" />
            <item name="Contributing" href="./contributing.html" />
            <item name="Security Policy" href="./SECURITY.html" />
        </menu>

        <menu ref="reports"/>

        <links>
            <item name="Apache" href="http://www.apache.org"/>
        </links>

        <footer>Copyright &copy; Aiven Oy. Licensed under the Apache License, Version 2.0.<![CDATA[<br/>
            Apache Commons Collection, Apache Kafka, and Apache Velocity are trademarks of The Apache Software Foundation.<br/>
            Salesforce is a trademark of Salesforce, Inc.<br/>
            All other marks mentioned may be trademarks or registered trademarks of their respective owners.]]></footer>

    </body>
    <skin>
        <groupId>org.apache.maven.skins</groupId>
        <artifactId>maven-fluido-skin</artifactId>
        <version>2.0.1</version>
    </skin>
    <custom>
        <fluidoSkin>
            <topBarEnabled>false</topBarEnabled>
            <sideBarEnabled>true</sideBarEnabled>
            <skipGenerationDate>true</skipGenerationDate>
            <gitHub>
                <projectId>Aiven-Open/salesforce-connector-for-apache-kafka</projectId>
                <ribbonOrientation>right</ribbonOrientation>
                <ribbonColor>orange</ribbonColor>
            </gitHub>
        </fluidoSkin>
    </custom>
</site>
